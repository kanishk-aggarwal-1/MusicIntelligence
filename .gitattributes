# Normalize line endings to LF on commit so diffs don't show phantom CRLF
# churn across machines. Working trees may still check out CRLF on Windows.
* text=auto eol=lf

# Source files: always LF in the repository.
*.py   text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.cfg  text eol=lf
*.ini  text eol=lf
*.txt  text eol=lf
*.sh   text eol=lf

# Binary assets: never touch.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  text eol=lf
*.woff binary
*.woff2 binary
